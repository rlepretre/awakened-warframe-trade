<Window x:Class="GameOcrOverlay.Windows.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        WindowStyle="None"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        MinWidth="320"
        MaxWidth="520"
        MaxHeight="520">
    <Border Background="#E61D232A"
            BorderBrush="#55FFFFFF"
            BorderThickness="1"
            CornerRadius="6"
            Padding="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock x:Name="TitleText"
                       Foreground="White"
                       FontSize="16"
                       FontWeight="SemiBold"
                       TextTrimming="CharacterEllipsis" />

            <ScrollViewer x:Name="BodyScrollViewer"
                          Grid.Row="1"
                          Margin="0,8,0,0"
                          VerticalScrollBarVisibility="Disabled"
                          HorizontalScrollBarVisibility="Disabled">
                <TextBlock x:Name="BodyText"
                           Foreground="#DDE7EF"
                           FontSize="12"
                           LineHeight="17"
                           TextWrapping="Wrap" />
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
